# .env 파일로 복사 후 실제 값 입력
# cp .env.example .env

ANTHROPIC_API_KEY=sk-ant-api03-여기에_실제_키_입력

# 분석 대상 사이트
TARGET_URL=https://soavela.com

# 추적할 키워드 (쉼표 구분)
KEYWORDS=금반지,금목걸이,금팔찌,순금반지,순금목걸이,돌반지,커플링,24k순금반지

# 순위 추적 검색 엔진 (google,naver 중 선택, 쉼표 구분)
SEARCH_ENGINES=google,naver

# 경쟁사 URL (쉼표 구분, 최대 3개 권장)
COMPETITORS=https://www.hanakumall.com,https://goldenbell.co.kr

# 결과물 저장 경로 (기본값 사용 가능)
OUTPUT_DIR=./output
